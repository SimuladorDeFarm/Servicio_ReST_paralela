# Copiar a .env y ajustar según necesidad: cp .env.example .env
# Todas las variables son opcionales; si no se definen, se usan los defaults
# indicados abajo.

# Ruta al CSV de ventas a cargar. Default: data/ventas_completas.csv
VENTAS_CSV_PATH=data/ventas_completas.csv

# Nº de procesos worker para la carga paralela. Default: nº de CPUs disponibles.
VENTAS_N_WORKERS=

# Chunks por worker durante la carga. Default: 2
VENTAS_CHUNKS_PER_WORKER=2

# Si se define, toda petición debe incluir el header X-API-Key con este
# mismo valor. Default: vacía (sin autenticación).
API_KEY=

# Orígenes permitidos para CORS, separados por coma. Default: *
CORS_ORIGINS=*
